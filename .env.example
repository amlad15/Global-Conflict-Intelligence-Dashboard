# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_PORT=3000
BACKEND_PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=gcid
POSTGRES_USER=gcid_user
POSTGRES_PASSWORD=gcid_password

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Frontend Public Env Vars ─────────────────────────────────────────────────
# Backend URLs for the browser to connect to
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Mapbox token (optional - app uses OpenStreetMap by default)
# Get a free token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── AI / Ollama ──────────────────────────────────────────────────────────────
# Ollama runs locally - install from https://ollama.ai
# Then run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_secret_in_production

# ─── Data Source API Keys ─────────────────────────────────────────────────────

# OpenSky Network (aircraft tracking) - optional, anonymous access works but has limits
# Register free at https://opensky-network.org/
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ACLED (conflict events) - free with registration
# Register at https://acleddata.com/register/
ACLED_API_KEY=
ACLED_EMAIL=

# AISStream.io (ship tracking) - free tier available
# Register at https://aisstream.io/
AISSTREAM_API_KEY=

# ─── Worker Poll Intervals (milliseconds) ─────────────────────────────────────
POLL_INTERVAL_AIRCRAFT=30000
POLL_INTERVAL_SHIPS=60000
POLL_INTERVAL_CONFLICTS=300000
POLL_INTERVAL_NEWS=120000
